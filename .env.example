# 千问 OpenAI 兼容模式
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# 文生图：火山方舟（Seedream / 豆包接入点）
IMAGE_PROVIDER=doubao
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
IMAGE_MODEL=ep-xxxxxxxx-xxxxx

# 图片尺寸（1:1 方图，1920x1920 满足方舟最小像素）
IMAGE_SIZE=1920x1920

# 阿里云 OSS
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=
OSS_PUBLIC_BASE_URL=
OSS_PREFIX=guseeit/rounds
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# 上传时对象 ACL，小游戏公网读图用 public-read
OSS_OBJECT_ACL=public-read

# 高德 Web 服务（逆地理 / 地理编码，与抖音地图一致）
AMAP_WEB_KEY=
AMAP_BASE_URL=https://restapi.amap.com/v3

# Web 出题台
HOST=0.0.0.0
PORT=8787

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=guseeit
